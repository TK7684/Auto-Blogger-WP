WP_URL=https://your-wordpress-site.com
WP_USER=your_username
WP_APP_PASSWORD=your_app_password
GEMINI_API_KEY=your_gemini_api_key
TRENDS_GEO=US
WP_CATEGORY_ID=1

# LLM backend priority (first one set wins):
# 1. ZAI_API_KEY       — Z.AI / GLM-5.1 (current production)
# 2. OPENROUTER_API_KEY — OpenRouter multi-provider gateway
# 3. LITELLM_MODEL      — LiteLLM escape hatch; unlocks SiliconFlow / Ollama / DeepSeek / 100+ providers
#    Examples:
#      LITELLM_MODEL=siliconflow/deepseek-v3
#      LITELLM_MODEL=ollama/llama3
#      LITELLM_MODEL=openrouter/deepseek/deepseek-chat
#    Provider-specific auth still required (e.g. SILICONFLOW_API_KEY, OLLAMA_API_BASE, etc.)
# 4. GEMINI_API_KEY via Vertex/Google — see gemini.py _initialize_client priority
# LITELLM_MODEL=siliconflow/deepseek-v3
# SILICONFLOW_API_KEY=your_siliconflow_api_key

# --- Affiliate (optional) ---
# Shopee Thailand Affiliate ID — get from https://affiliate.shopee.co.th/ dashboard
# When set, each published article gets a Shopee CTA card appended.
SHOPEE_AFFILIATE_ID=
# Optional: comma-separated pre-generated deep links (from Shopee dashboard Link Generator)
# When provided, one is picked deterministically per article as a "featured product" link.
# SHOPEE_AFFILIATE_LINKS=https://s.shopee.co.th/ABC123,https://s.shopee.co.th/XYZ789

# --- Shopee Affiliate API (Python client) ---
# Required for dynamic product fetching via API
# Get from: https://affiliate.shopee.co.th/ → Developer section
# SHOPEE_APP_ID=your_app_id
# SHOPEE_APP_SECRET=your_app_secret
# SHOPEE_API_ENDPOINT=https://open-api.affiliate.shopee.co.th/graphql
